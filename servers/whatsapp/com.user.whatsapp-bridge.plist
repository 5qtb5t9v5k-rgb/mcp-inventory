<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.whatsapp-bridge</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/you/code/whatsapp-mcp/whatsapp-bridge/whatsapp-bridge</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/you/code/whatsapp-mcp/whatsapp-bridge</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/you/Library/Logs/whatsapp-bridge.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/you/Library/Logs/whatsapp-bridge.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
